{
  "expo": {
    "name": "expo-nativewind",
    "slug": "expo-nativewind",
    "scheme": "expo-nativewind",
    "experiments": {
      "typedRoutes": true
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.x1lkin.exponativewind"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.x1lkin.exponativewind"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Axios to access your camera to scan QR"
        }
      ],
      [
        "expo-notifications"
      ],
      "expo-localization"
    ]
  }
}
